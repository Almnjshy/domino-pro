import React, { useState } from 'react';
import { View, StyleSheet, TouchableOpacity, ScrollView } from 'react-native';
import Animated, { useSharedValue, useAnimatedStyle, withSpring } from 'react-native-reanimated';
import { DominoTile } from './DominoTile';
import { DominoTile as DominoTileType } from '../core/types';

interface HandProps {
  tiles: DominoTileType[];
  onTileSelect: (tileId: string) => void;
  onTileDrop: (tileId: string, side: 'left' | 'right') => void;
  disabled?: boolean;
}

export const Hand: React.FC<HandProps> = ({ tiles, onTileSelect, onTileDrop, disabled }) => {
  const [selectedId, setSelectedId] = useState<string | null>(null);

  const handlePress = (tileId: string) => {
    if (disabled) return;
    if (selectedId === tileId) {
      setSelectedId(null);
    } else {
      setSelectedId(tileId);
      onTileSelect(tileId);
    }
  };

  const handlePlay = (tileId: string) => {
    if (selectedId === tileId) {
      onTileDrop(tileId, 'right');
      setSelectedId(null);
    }
  };

  const tileWidth = tiles.length > 8 ? 45 : tiles.length > 6 ? 52 : 60;
  const tileHeight = tileWidth * 2;

  return (
    <View style={styles.container}>
      <ScrollView horizontal showsHorizontalScrollIndicator={false}
        contentContainerStyle={styles.handContent}>
        {tiles.map((tile, idx) => (
          <TouchableOpacity
            key={tile.id}
            activeOpacity={0.8}
            onPress={() => handlePress(tile.id)}
            onLongPress={() => handlePlay(tile.id)}
            style={[
              styles.tileSlot,
              { marginLeft: idx === 0 ? 0 : -8 },
              selectedId === tile.id && styles.tileSelected
            ]}
          >
            <Animated.View style={selectedId === tile.id ? { transform: [{ scale: 1.15 }, { translateY: -15 }] } : {}}>
              <DominoTile
                left={tile.left} right={tile.right}
                width={tileWidth} height={tileHeight}
                selected={selectedId === tile.id}
              />
            </Animated.View>
          </TouchableOpacity>
        ))}
      </ScrollView>
      {selectedId && (
        <View style={styles.hint}>
          <TouchableOpacity onPress={() => { onTileDrop(selectedId, 'left'); setSelectedId(null); }}
            style={styles.sideBtn}>
            <View style={styles.sideText}><>◀ يسار</></View>
          </TouchableOpacity>
          <TouchableOpacity onPress={() => { onTileDrop(selectedId, 'right'); setSelectedId(null); }}
            style={styles.sideBtn}>
            <View style={styles.sideText}><>يمين ▶</></View>
          </TouchableOpacity>
        </View>
      )}
    </View>
  );
};

const styles = StyleSheet.create({
  container: {
    minHeight: 160,
    justifyContent: 'center',
    backgroundColor: 'rgba(0,0,0,0.4)',
    borderTopWidth: 1,
    borderTopColor: 'rgba(255,255,255,0.1)',
  },
  handContent: { paddingHorizontal: 16, alignItems: 'center', paddingVertical: 10 },
  tileSlot: {
    shadowColor: '#000', shadowOffset: { width: 0, height: 4 },
    shadowOpacity: 0.3, shadowRadius: 6, elevation: 8,
  },
  tileSelected: { zIndex: 10 },
  hint: {
    flexDirection: 'row', justifyContent: 'center', gap: 16,
    paddingVertical: 8, backgroundColor: 'rgba(0,0,0,0.6)',
  },
  sideBtn: {
    backgroundColor: '#d4af37', paddingHorizontal: 20,
    paddingVertical: 8, borderRadius: 20,
  },
  sideText: { color: '#000', fontWeight: 'bold' },
});